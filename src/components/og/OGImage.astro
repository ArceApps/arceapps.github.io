---
/**
 * OG Image SVG Template Component
 * 
 * This component defines the SVG template for OG image generation.
 * Used by scripts/generate-og-images.ts during build.
 * 
 * Brand colors: Teal #018786, Orange #FF9800
 * Dimensions: 1200x630
 */

interface Props {
  title: string;
  date: string;
  type: 'blog' | 'apps' | 'devlog';
  lang: 'en' | 'es';
}

const { title, date, type, lang } = Astro.props;

const typeLabels = {
  blog: 'Blog',
  apps: 'App',
  devlog: 'Devlog',
};

const langLabel = lang === 'es' ? 'ES' : 'EN';

const formattedDate = new Date(date).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#018786;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#006666;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="accentGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#FF9800;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FFB74D;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bgGrad)" />
  
  <!-- Decorative circles -->
  <circle cx="1100" cy="100" r="300" fill="#FF9800" opacity="0.1" />
  <circle cx="100" cy="600" r="200" fill="#FFFFFF" opacity="0.05" />
  
  <!-- Accent bar -->
  <rect x="0" y="580" width="1200" height="50" fill="url(#accentGrad)" />
  
  <!-- Type badge -->
  <rect x="80" y="80" width="140" height="40" rx="20" fill="#FF9800" />
  <text x="150" y="106" font-family="Roboto, sans-serif" font-size="16" font-weight="700" fill="#FFFFFF" text-anchor="middle">{typeLabels[type]}</text>
  
  <!-- Language badge -->
  <rect x="240" y="80" width="50" height="40" rx="20" fill="#FFFFFF" opacity="0.2" />
  <text x="265" y="106" font-family="Roboto, sans-serif" font-size="14" font-weight="700" fill="#FFFFFF" text-anchor="middle">{langLabel}</text>
  
  <!-- Title (max 2 lines with ellipsis) -->
  <foreignObject x="80" y="140" width="1000" height="200">
    <div style="font-family: Roboto, sans-serif; font-size: 56px; font-weight: 700; fill: #FFFFFF; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
      {title}
    </div>
  </foreignObject>
  
  <!-- Divider -->
  <rect x="80" y="320" width="80" height="4" rx="2" fill="#FF9800" />
  
  <!-- Date -->
  <text x="80" y="400" font-family="Roboto, sans-serif" font-size="24" fill="#FFFFFF" opacity="0.8">{formattedDate}</text>
  
  <!-- Brand watermark -->
  <text x="1100" y="600" font-family="Roboto, sans-serif" font-size="20" font-weight="700" fill="#FFFFFF" opacity="0.6" text-anchor="end">ArceApps</text>
</svg>